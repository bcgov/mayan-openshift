#: views.py:59
msgid "This tool erases and populates the search backend's internal index."
msgstr "ལག་ཆ་འདིས་འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ཀྱི་ནང་ཁུལ་གྱི་དཀར་ཆག་བསུབས་ནས་བཀང་ཐུབ།"

#: views.py:69
msgid ""
"This tool is required only for some search backends. Search results will be "
"affected while the backend is being reindexed."
msgstr ""
"ལག་ཆ་འདི་འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ཁ་ཤས་ལ་རྐྱངམ་གཅིག་དགོས། "
"རྒྱབ་ཕྱོགས་དེ་བསྐྱར་དུ་དཀར་ཆག་བཟོ་བའི་སྐབས་འཚོལ་ཞིབ་གྲུབ་འབྲས་ལ་ཤུགས་རྐྱེན་ཐེབས་རྒྱུ་རེད།"

#: views.py:75
msgid ""
"The currently selected search backend does not support or requires "
"reindexing."
msgstr ""
"ད་ལྟ་འདེམས་པའི་འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ཀྱིས་རྒྱབ་སྐྱོར་བྱེད་ཀྱི་མེད་པའམ་ཡང་ན་བསྐྱར་དུ་དཀར་ཆག་བཟོ་དགོས།"

#: views.py:88
msgid "Search backend reindexing queued."
msgstr "འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་བསྐྱར་དུ་དཀར་ཆག་བསྒྲིགས་ཡོད།"

