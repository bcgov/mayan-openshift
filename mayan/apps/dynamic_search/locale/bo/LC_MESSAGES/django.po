msgstr "འཚོལ་བཤེར་ལག་ཆ་ལག་བསྟར་བྱེད་པ།"

#: queues.py:10
msgid "Search slow"
msgstr "འཚོལ་ཞིབ་དལ་བ།"

#: queues.py:15
msgid "Remove a model instance from the search engine."
msgstr "འཚོལ་ཞིབ་འཕྲུལ་ཆས་ནས་དཔེ་མཚོན་གྱི་དཔེ་མཚོན་ཞིག་མེད་པར་བཟོས།"

#: queues.py:20
msgid "Index a model instance to the search engine."
msgstr "འཚོལ་ཞིབ་འཕྲུལ་ཆས་ལ་དཔེ་ཚད་ཀྱི་དཔེ་མཚོན་ཞིག་དཀར་ཆག་བཟོས།"

#: queues.py:25
msgid "Index all instances of a search model to the search engine."
msgstr "འཚོལ་ཞིབ་འཕྲུལ་ཆས་ལ་འཚོལ་ཞིབ་དཔེ་གཞིའི་གནས་ཚུལ་ཚང་མ་ཟུར་ཐོ་བཟོས།"

#: queues.py:31
msgid ""
"Index all related instances of a search model after a many to many event."
msgstr ""
"བྱུང་རིམ་མང་པོ་ནས་མང་པོ་བྱུང་རྗེས་འཚོལ་ཞིབ་དཔེ་གཞིའི་འབྲེལ་ཡོད་གནས་ཚུལ་ཚང་མ་ཟུར་ཐོ་བཟོས།"

#: queues.py:39
msgid "Reset the search backend indices and index all instances again."
msgstr ""
"འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ཀྱི་ཟུར་ཐོ་སླར་གསོ་བྱས་ནས་གནས་ཚུལ་ཚང་མ་ཡང་བསྐྱར་ཟུར་ཐོ་བཟོས།"

#: scoped_queries.py:353
msgid ""
"Search results exceed limit setting. Results might not be reliable if "
"multiple scopes are used. Narrow down the search criteria or increase the "
"value of the results limit setting."
msgstr ""
"འཚོལ་ཞིབ་གྲུབ་འབྲས་ཚད་གཞི་ལས་བརྒལ་ཡོད། "
"གལ་ཏེ་ཁྱབ་ཁོངས་སྣ་ཚོགས་བེད་སྤྱོད་བཏང་ན་གྲུབ་འབྲས་བརྟན་པོ་མེད་སྲིད། "
"འཚོལ་ཞིབ་ཚད་གཞི་དོག་པོ་བཟོ་བའམ་ཡང་ན་གྲུབ་འབྲས་ཚད་གཞི་སྒྲིག་སྟངས་ཀྱི་རིན་ཐང་ཆེ་རུ་གཏོང་བ།"

#: scoped_queries.py:375
#, python-format
msgid ""
"Search backend error. Verify that the search service is available and that "
"the search syntax is valid for the active search backend; %s"
msgstr ""
"རྒྱབ་ཕྱོགས་ཀྱི་ནོར་འཁྲུལ་འཚོལ་ཞིབ་བྱས། "
"འཚོལ་ཞིབ་ཞབས་ཞུ་ཡོད་མེད་དང་འཚོལ་ཞིབ་ཚིག་སྦྱོར་དེ་ཤུགས་ལྡན་འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ལ་ནུས་ལྡན་ཡིན་མིན་བདེན་དཔང་བྱེད།"
" %s"

