#: settings.py:22
msgid "Full path to the backend to be used to handle the search."
msgstr ""
"འཚོལ་ཞིབ་ལ་འགན་ལེན་བྱེད་པར་བེད་སྤྱོད་གཏོང་བའི་རྒྱབ་ཕྱོགས་ལ་འགྲོ་ལམ་ཆ་ཚང་།"

#: settings.py:29
msgid ""
"Arguments to pass to the search backend. For example values to change the "
"behavior, host names, or authentication arguments."
msgstr ""
"འཚོལ་ཞིབ་རྒྱབ་ཕྱོགས་ལ་སྤྲོད་པའི་རྩོད་གླེང་། དཔེར་ན་ "
"སྤྱོད་ལམ་བསྒྱུར་བཅོས་བྱེད་པའི་གནས་གོང་དང་། གཙོ་བོའི་མིང་། "
"ཡང་ན་བདེན་དཔང་སྒྲུབ་བྱེད།"

#: settings.py:38
msgid "The search operator to use when none is specified."
msgstr ""
"གང་ཡང་གསལ་བཀོད་བྱས་མེད་པའི་སྐབས་བེད་སྤྱོད་གཏོང་བའི་འཚོལ་ཞིབ་བཀོལ་སྤྱོད་པ།"

#: settings.py:45
msgid ""
"Disables the single term bar search leaving only the advanced search button."
msgstr ""
"ཡར་ཐོན་ཅན་གྱི་འཚོལ་ཞིབ་མཐེབ་ཁོ་ན་བཞག་སྟེ་མིང་ཚིག་རྐྱང་པའི་ཕྲ་རིང་འཚོལ་ཞིབ་ལྕོགས་མིན་བཟོས།"

#: settings.py:53
msgid "Amount of objects to process when performing bulk indexing."
msgstr "དཀར་ཆག་མང་པོ་སྒྲུབ་སྐབས་ལས་སྣོན་བྱེད་དགོས་པའི་དངོས་པོའི་ཚད་གཞི།"

#: settings.py:59
msgid "Sets the default state of the \"Match all\" checkbox."
msgstr ""
"&quot;ཚང་མ་མཐུན་སྒྲིག་&quot; "
"ཞིབ་བཤེར་སྒྲོམ་གྱི་སྔོན་སྒྲིག་གནས་སྟངས་སྒྲིག་བཀོད་བྱེད།"

#: settings.py:65
msgid ""
"Maximum number of search results to fetch and display per search query unit."
msgstr ""
"འཚོལ་ཞིབ་འདྲི་རྩད་ཀྱི་ཆ་ཤས་རེ་ལ་འཚོལ་ཞིབ་གྲུབ་འབྲས་ཆེས་མཐོ་བའི་གྲངས་འབོར།"

#: settings.py:72
msgid ""
"Raise an error when the number of search results exceed the value of "
"`SEARCH_QUERY_RESULTS_LIMIT`."
msgstr ""

