#: literals.py:7
msgid ""
"The document files have been compressed and are available for download using"
" the link: {{ download_url }} or from the downloads area ({{ "
"download_list_url }})."
msgstr ""
"I file del documento sono stati compressi e sono disponibili per il download"
" tramite il link: {{ download_url }} oppure dall'area download ({{ "
"download_list_url }})."

#: literals.py:13
msgid "Document files ready for download."
msgstr "File del documento pronti per il download."

#: permissions.py:10
msgid "Download document files"
msgstr "Scarica i file del documento"

#: queues.py:13
msgid "Generate a compressed document file bundle"
msgstr "Genera un archivio compresso dei file del documento"

#: settings.py:21
msgid "Path to the download subclass to use when downloading document files."
msgstr ""
"Percorso della sottoclasse di download da utilizzare per scaricare i file "
"del documento."

#: settings.py:29
msgid ""
"Arguments to pass to the DOCUMENT_DOWNLOADS_DOCUMENT_FILE_DOWNLOAD_BACKEND."
msgstr ""
"Argomenti da passare a  DOCUMENT_DOWNLOADS_DOCUMENT_FILE_DOWNLOAD_BACKEND."

#: settings.py:36
msgid ""
"Template for the document download message body text. Can include HTML. "
"Available variables: {}"
msgstr ""
"Template per il testo del corpo del messaggio di download del documento. Può"
" includere HTML. Variabili disponibili: {}"

#: settings.py:45
msgid ""
"Template for the document download message subject line. Can't include HTML."
" Available variables: {}"
msgstr ""
"Template per l’oggetto del messaggio di download del documento. Non può "
"includere HTML. Variabili disponibili: {}"

#: views.py:32
#, python-format
msgid ""
"Unable to queued document \"%(instance)s\" for file download; %(exception)s."
