msgstr "%(count)d file dei documenti messi in coda per il download."

#: views.py:44
#, python-format
msgid "Document file \"%(object)s\" queued for download."
msgstr "File del documento \"%(object)s\" messo in coda per il download."

#: views.py:47
#, python-format
msgid "%(count)d document file queued for download."
msgstr "%(count)d file del documento messo in coda per il download."

#: views.py:49
#, python-format
