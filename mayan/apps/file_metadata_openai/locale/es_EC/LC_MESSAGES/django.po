#: apps.py:10
msgid "File metadata OpenAI"
msgstr "Metadatos de archivos OpenAI"

#: drivers.py:21
msgid "Analyze content using OpenAI's Response API."
msgstr "Analiza contenido utilizando la API de respuesta de OpenAI."

#: drivers.py:24
msgid "OpenAI Response API driver"
msgstr "Controlador de API de respuesta de OpenAI"

#: drivers.py:31
msgid "Basic"
msgstr "Básico"

#: drivers.py:36
msgid "Authentication"
msgstr "Autenticación  "

#: drivers.py:41
msgid "Control"
msgstr "Control"

#: drivers.py:46
msgid "Prompt"
msgstr "Mensaje"

#: drivers.py:51
msgid "Communication"
msgstr "Comunicación"

#: drivers.py:59
msgid ""
"API endpoint base URL. Change this only when using a compatible non-default "
"endpoint or proxy. The document file object is available as {{ document_file"
" }}."
msgstr ""

#: drivers.py:62
msgid "Base URL"
msgstr "URL base"

#: drivers.py:66
msgid ""
"The API key used for authentication. The document file object is available "
"as {{ document_file }}."
msgstr ""
"La llave API utilizada para la autenticación. El objeto de archivo de "
"documento está disponible como {{document_file}}."

#: drivers.py:68
msgid "API Key"
msgstr "Llave API"

#: drivers.py:72
msgid ""
"Text or file content to send to the OpenAI API for analysis. The document "
"file object is available as {{ document_file }}."
msgstr ""
"Contenido de texto o archivo para enviar a la API de OpenAI para su "
"análisis. El objeto de archivo de documento está disponible como "
"{{document_file}}."

#: drivers.py:75
msgid "Input"
msgstr "Entrada"

#: drivers.py:79
msgid ""
"Identifier of the OpenAI model to use (for example: gpt-5, gpt-5-nano). The "
"document file object is available as {{ document_file }}."
msgstr ""

#: drivers.py:82
msgid "Model"
msgstr "Modelo"

#: drivers.py:86
msgid ""
"Optional OpenAI organization ID. Used when the API key is linked to multiple"
" organizations. The document file object is available as {{ document_file "
"}}."
msgstr ""

#: drivers.py:89
msgid "Organization"
msgstr "Organización"

#: drivers.py:93
msgid ""
"Optional OpenAI project ID. Allows scoping requests to a specific project.  "
"The document file object is available as {{ document_file }}."
msgstr ""

#: drivers.py:96
msgid "Project"
msgstr "Proyecto"

#: drivers.py:100
msgid ""
"Maximum time (in seconds) to wait for a response from the API before "
"failing.  The document file object is available as {{ document_file }}."
msgstr ""

#: drivers.py:103
msgid "Timeout"
msgstr "Tiempo de expiración"
