{% load platforms_gitlab_tags %}

job_python_build:
  artifacts:
    expire_in: 24 hr
    paths:
    - dist
  before_script:
{% platforms_gitlab_ci_cache_before_script apt=True indent=4 %}
    - apt-get install --yes --no-install-recommends {{ LINUX_PACKAGES_DEBIAN_BUILD }} {{ LINUX_PACKAGES_DEBIAN_PYTHON }}
    - python3 -m venv venv
    - . venv/bin/activate
    - make dev-setup-python-essential
    - make dev-setup-python-build
  cache:
{% platforms_gitlab_ci_cache_paths apt=True indent=4 pip=True %}
  image: {{ DOCKER_LINUX_IMAGE_NAME }}:{{ DOCKER_LINUX_IMAGE_TAG }}
  only:
    - {{ GITLAB_CI_BRANCH_BUILDS_PYTHON }}
    - {{ GITLAB_CI_BRANCH_RELEASES_ALL_MAJOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_ALL_MINOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_DOCKER_MAJOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_DOCKER_MINOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_PYTHON_MAJOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_PYTHON_MINOR }}
    - {{ GITLAB_CI_BRANCH_RELEASES_TESTING }}
    - {{ GITLAB_CI_BRANCH_TESTS_ALL }}
    - {{ GITLAB_CI_BRANCH_TESTS_PYTHON }}
  script:
    - make python-wheel-production
  stage: stage_build_python
  variables:
{% platforms_gitlab_ci_cache_variables apt=True indent=4 pip=True %}
