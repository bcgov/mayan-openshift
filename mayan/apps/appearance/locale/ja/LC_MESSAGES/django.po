#: templates/500.html:5 templates/500.html:30
#: templates/appearance/root.html:46
msgid "Server error"
msgstr "サーバーエラー"

#: templates/500.html:32
msgid "There's been an unexpected error."
msgstr "予期しないエラーが発生しました。"

#: templates/500.html:40
msgid "What to do next?"
msgstr "次に行うべきことは何ですか？"

#: templates/500.html:44
msgid "Refresh the page."
msgstr "ページを更新してください。"

#: templates/500.html:45
msgid "Wait a bit. The system might be overloaded."
msgstr "少々お待ち下さい。システムが過負荷になっている可能性があります。"

#: templates/500.html:46
msgid "Contact your system administrator."
msgstr "システム管理者に連絡してください。"

#: templates/500.html:47
msgid "Check the logs for messages with the tags \"ERROR\", \"CRITICAL\" or \"FATAL\"."
msgstr "ログを確認し、「ERROR」「CRITICAL」「FATAL」のタグが付いたメッセージを探してください。"

#: templates/500.html:48
#, python-format
msgid "Open a ticket using the <a href=\"%(issue_url)s\">issue tracker</a>."
msgstr "<a href=\"%(issue_url)s\">課題管理ツール(issue tracker)</a>を使ってチケットを作成してください。"

#: templates/appearance/about.html:10
msgid "About"
msgstr "概要"

#: templates/appearance/about.html:39
msgid "Version"
msgstr "バージョン"

