msgid "Position where the system messages will be displayed."
msgstr "མ་ལག་གི་འཕྲིན་ཡིག་བཀྲམ་སྟོན་བྱེད་སའི་གནས་ཡུལ།"

#: settings.py:40
msgid ""
"Delay in milliseconds after which the menus will be checked for updates."
msgstr ""
"མི་ལི་སྐར་ཆའི་ནང་ཕྱིར་འགྱངས་བྱས་རྗེས་དཀར་ཆག་དེ་ཚོ་གསར་བརྗེ་བྱེད་པར་བརྟག་དཔྱད་བྱེད།"

#: settings.py:47
msgid ""
"Maximum number of requests that can be made before throttling is enabled."
msgstr "ཆེས་མཐོའི་འབོད་སྐུལ་གྱི་གྲངས་འབོར།"

#: settings.py:54
msgid ""
"Time in milliseconds after which a throttled request will clear allowing an "
"additional request to be performed."
msgstr ""
"མི་ལི་སྐར་ཆའི་ནང་དུས་ཚོད། "
"དེའི་རྗེས་སུ་ཚད་གཞི་ཆུང་བའི་རེ་འདུན་དེ་བསལ་ནས་རེ་འདུན་ཁ་སྣོན་ཞིག་སྒྲུབ་ཐུབ།"

