#: templates/404.html:44
msgid "The location of the item is incorrect."
msgstr "རྣམ་གྲངས་ཀྱི་གནས་ཡུལ་མི་འགྲིག་པ།"

#: templates/404.html:45
msgid "The location is correct, but the item no longer exists."
msgstr "གནས་ཡུལ་དེ་བདེན་པ་རེད། འོན་ཀྱང་རྣམ་གྲངས་དེ་ད་ལྟ་མེད་པ་རེད།"

#: templates/404.html:46
msgid ""
"The location is be correct, but your account does not have the required "
"permission to access it."
msgstr ""
"གནས་ཡུལ་དེ་བདེན་པ་རེད། "
"འོན་ཀྱང་ཁྱེད་ཀྱི་ཁ་བྱང་ལ་དེ་ལ་འཛུལ་སྤྱོད་བྱེད་པའི་ཆོག་མཆན་མེད།"

